// GGH — Gomla Go Home (جملة لحد البيت)
// Database Schema — All entities for the wholesale grocery platform
// Money stored as integer piastres (EGP 14.50 = 1450)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & IDENTITY
// ============================================

model Customer {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String    @unique @default("")
  firstName     String    @default("")
  lastName      String    @default("")
  nameAr        String    @default("")
  preferredLang String    @default("ar")
  wholesaleStatus String  @default("retail") // retail | wholesale | vip
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Relations
  addresses     Address[]
  orders        Order[]
  cartItems     CartItem[]
  wishlists     Wishlist[]
  orderTemplates OrderTemplate[]
  reviews       Review[]
  otpCodes      OtpCode[]
  sessions      Session[]
  adminUser     AdminUser?
  priceRules    PriceRule[]
  paymentTransactions PaymentTransaction[]
  loyaltyTransactions LoyaltyTransaction[]
  notificationSubscriptions NotificationSubscription[]
  notificationLogs     NotificationLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@map("customers")
}

model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  code       String
  attempts   Int      @default(0)
  verified   Boolean  @default(false)
  expiresAt  DateTime
  customerId String?

  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())

  @@index([phone, code])
  @@map("otp_codes")
}

model Session {
  id          String   @id @default(cuid())
  token       String   @unique
  customerId  String
  deviceInfo  String   @default("")
  ipAddress   String   @default("")
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  customer    Customer @relation(fields: [customerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([customerId])
  @@map("sessions")
}

// ============================================
// ADMIN & RBAC
// ============================================

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  nameEn        String
  nameAr        String    @default("")
  phone         String    @default("")
  passwordHash  String    @default("")
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  customerId    String?  @unique

  customer      Customer? @relation(fields: [customerId], references: [id])
  roles         AdminUserRole[]
  sessions      AdminSession[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@map("admin_users")
}

model AdminSession {
  id          String    @id @default(cuid())
  token       String    @unique
  adminId     String
  deviceInfo  String    @default("")
  ipAddress   String    @default("")
  expiresAt   DateTime
  isActive    Boolean   @default(true)

  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([token])
  @@map("admin_sessions")
}

model Role {
  id          String    @id @default(cuid())
  name        String    @unique
  nameEn      String
  nameAr      String
  description String    @default("")
  isSystem    Boolean   @default(false)

  adminUsers  AdminUserRole[]
  permissions RolePermission[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("roles")
}

model Permission {
  id          String    @id @default(cuid())
  name        String    @unique
  nameEn      String
  nameAr      String
  module      String
  action      String

  roles       RolePermission[]

  createdAt   DateTime  @default(now())

  @@index([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String  @id @default(cuid())
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AdminUserRole {
  id       String  @id @default(cuid())
  adminId  String
  roleId   String

  admin    AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role     Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([adminId, roleId])
  @@map("admin_user_roles")
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  nameEn      String
  nameAr      String
  descriptionEn String  @default("")
  descriptionAr String  @default("")
  icon        String    @default("")
  color       String    @default("#F5F5F5")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  parentId    String?

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  priceRules  PriceRule[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@map("categories")
}

model Product {
  id              String    @id @default(cuid())
  handle          String    @unique
  nameEn          String
  nameAr          String
  descriptionEn   String    @default("")
  descriptionAr   String    @default("")
  brandEn         String    @default("")
  brandAr         String    @default("")
  weight          String    @default("")
  unit            String    @default("piece")
  barcode         String?
  todayPrice      Int       @default(0)
  yesterdayPrice  Int?
  wholesalePrice  Int?
  costPrice       Int?
  compareAtPrice  Int?
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  totalSold       Int       @default(0)
  stock           Int       @default(0)
  lowStockThreshold Int     @default(5)
  icon            String    @default("")
  imageUrl        String?
  thumbnailUrl    String?
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  isDeal          Boolean   @default(false)
  dealEndsAt      DateTime?
  maxPerOrder     Int       @default(10)
  minOrderQty     Int       @default(1)
  categoryId      String

  category        Category  @relation(fields: [categoryId], references: [id])
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlists       Wishlist[]
  reviews         Review[]
  productImages   ProductImage[]
  deals           Deal[]
  priceRules      PriceRule[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([categoryId])
  @@index([handle])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isDeal])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  altEn     String  @default("")
  altAr     String  @default("")
  sortOrder Int     @default(0)
  productId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ============================================
// CART & CHECKOUT
// ============================================

model CartItem {
  id         String  @id @default(cuid())
  customerId String?
  sessionId  String?
  productId  String
  quantity   Int     @default(1)
  unitPrice  Int

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([sessionId])
  @@map("cart_items")
}

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  customerId      String
  status          String    @default("pending")
  paymentMethod   String    @default("cod")
  paymentStatus   String    @default("pending")
  subtotal        Int       @default(0)
  deliveryFee     Int       @default(0)
  discountAmount  Int       @default(0)
  totalAmount     Int       @default(0)
  notes           String    @default("")
  deliveryAddressId String?
  deliveryAddressSnapshot String @default("")
  deliverySlot    String    @default("")
  deliveryDate    DateTime?
  deliveredAt     DateTime?
  driverId        String?
  driverName      String    @default("")
  driverPhone     String    @default("")
  erpSalesOrder   String    @default("")
  erpSyncStatus   String    @default("pending")
  erpSyncedAt     DateTime?

  customer        Customer   @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  assignment      DeliveryAssignment?
  shipment        Shipment?
  paymentTransactions PaymentTransaction[]
  loyaltyTransactions LoyaltyTransaction[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productNameEn String
  productNameAr String
  brandEn     String  @default("")
  brandAr     String  @default("")
  weight      String  @default("")
  icon        String  @default("")
  quantity    Int
  unitPrice   Int
  totalPrice  Int

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String   @default("")
  changedBy String   @default("system")

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================
// ADDRESSES
// ============================================

model Address {
  id            String   @id @default(cuid())
  customerId    String
  label         String   @default("home")
  addressLine1  String
  addressLine2  String   @default("")
  city          String   @default("Cairo")
  area          String   @default("")
  buildingNo    String   @default("")
  floorNo       String   @default("")
  apartmentNo   String   @default("")
  landmark      String   @default("")
  latitude      Float?
  longitude     Float?
  deliveryZone  String   @default("")
  isDefault     Boolean  @default(false)
  deliveryInstructions String @default("")

  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([customerId])
  @@map("addresses")
}

// ============================================
// WISHLISTS & REVIEWS
// ============================================

model Wishlist {
  id         String  @id @default(cuid())
  customerId String
  productId  String

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@map("wishlists")
}

model Review {
  id         String  @id @default(cuid())
  customerId String
  productId  String
  rating     Int
  commentEn  String  @default("")
  commentAr  String  @default("")
  isVerified Boolean @default(false)

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([customerId])
  @@map("reviews")
}

// ============================================
// ORDER TEMPLATES (Reorder)
// ============================================

model OrderTemplate {
  id          String  @id @default(cuid())
  customerId  String
  nameEn      String  @default("My Template")
  nameAr      String  @default("قوالبي")
  isDefault   Boolean @default(false)

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items       OrderTemplateItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@map("order_templates")
}

model OrderTemplateItem {
  id         String  @id @default(cuid())
  templateId String
  productId  String
  quantity   Int     @default(1)

  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("order_template_items")
}

// ============================================
// DELIVERY ZONES
// ============================================

model DeliveryZone {
  id          String  @id @default(cuid())
  nameEn      String
  nameAr      String
  area        String
  city        String  @default("Cairo")
  deliveryFee Int     @default(0)
  minOrder    Int     @default(0)
  estimatedHours Int  @default(24)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  priceRules  PriceRule[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("delivery_zones")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String   @id @default(cuid())
  customerId  String
  titleEn     String
  titleAr     String
  bodyEn      String
  bodyAr      String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  actionUrl   String?

  createdAt   DateTime @default(now())

  @@index([customerId, isRead])
  @@map("notifications")
}

// ============================================
// DEALS & PROMOTIONS
// ============================================

model Deal {
  id            String    @id @default(cuid())
  productId     String
  dealPrice     Int
  originalPrice Int
  discountPercent Int
  startsAt      DateTime
  endsAt        DateTime
  maxQuantity   Int       @default(100)
  claimedCount  Int       @default(0)
  isActive      Boolean   @default(true)

  product       Product   @relation(fields: [productId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, endsAt])
  @@map("deals")
}

// ============================================
// WAREHOUSE & LOGISTICS
// ============================================

model Warehouse {
  id          String  @id @default(cuid())
  nameEn      String
  nameAr      String
  address     String
  city        String  @default("Cairo")
  area        String
  latitude    Float
  longitude   Float
  phone       String
  isActive    Boolean @default(true)
  capacity    Int     @default(0)
  currentLoad Int     @default(0)

  drivers     Driver[]
  fulfillmentBatches FulfillmentBatch[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("warehouses")
}

model Driver {
  id          String  @id @default(cuid())
  nameEn      String
  nameAr      String
  phone       String  @unique
  warehouseId String?
  vehicleType String  @default("motorcycle")
  vehiclePlate String @default("")
  isActive    Boolean @default(true)
  isAvailable Boolean @default(true)
  rating      Float   @default(5.0)
  totalDeliveries Int @default(0)

  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  assignments DeliveryAssignment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("drivers")
}

// ============================================
// ERP INTEGRATION
// ============================================

model ErpSyncLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  erpDocType  String
  erpDocName  String?
  status      String   @default("pending")
  request     String?
  response    String?
  error       String?
  retryCount  Int      @default(0)
  syncedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@map("erp_sync_logs")
}

// ============================================
// GEOFENCING
// ============================================

model Geofence {
  id          String   @id @default(cuid())
  nameEn      String
  nameAr      String
  type        String
  centerLat   Float?
  centerLng   Float?
  radius      Float?
  points      String
  metadata    String   @default("{}")
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("geofences")
}

// ============================================
// GPS POSITION LOGS
// ============================================

model GpsPositionLog {
  id           String   @id @default(cuid())
  entityId     String
  entityType   String
  latitude     Float
  longitude    Float
  heading      Float    @default(0)
  speed        Float    @default(0)
  accuracy     Float    @default(0)
  batteryLevel Int?
  timestamp    DateTime

  @@index([entityId, timestamp])
  @@index([entityType])
  @@map("gps_position_logs")
}

// ============================================
// DELIVERY ASSIGNMENTS
// ============================================

model DeliveryAssignment {
  id            String   @id @default(cuid())
  orderId       String   @unique
  driverId      String
  warehouseId   String?
  status        String   @default("assigned")
  assignedAt    DateTime @default(now())
  acceptedAt    DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  notes         String   @default("")

  order         Order    @relation(fields: [orderId], references: [id])
  driver        Driver   @relation(fields: [driverId], references: [id])

  @@index([orderId])
  @@index([driverId])
  @@index([status])
  @@map("delivery_assignments")
}

// ============================================
// PRICE RULES
// ============================================

model PriceRule {
  id              String    @id @default(cuid())
  nameEn          String
  nameAr          String    @default("")
  type            String    // percentage_discount, fixed_discount, bulk_tier, wholesale_markup, zone_pricing
  value           Int       // piastres for fixed, or percentage
  minQuantity     Int       @default(0)
  maxQuantity     Int?
  minOrderTotal   Int       @default(0)
  customerId      String?
  customerGroup   String    @default("")
  categoryId      String?
  productId       String?
  zoneId          String?
  priority        Int       @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean   @default(true)

  customer        Customer?    @relation(fields: [customerId], references: [id])
  category        Category?    @relation(fields: [categoryId], references: [id])
  product         Product?     @relation(fields: [productId], references: [id])
  zone            DeliveryZone? @relation(fields: [zoneId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@index([isActive, priority])
  @@map("price_rules")
}

// ============================================
// BULK IMPORT/EXPORT
// ============================================

model BulkImportJob {
  id            String   @id @default(cuid())
  type          String   // products, categories, inventory, customers
  fileName      String
  fileSize      Int      @default(0)
  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  failedRows    Int      @default(0)
  status        String   @default("pending")
  errors        String   @default("")
  result        String   @default("")
  adminId       String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([adminId])
  @@index([status])
  @@map("bulk_import_jobs")
}

// ============================================
// FULFILLMENT
// ============================================

model FulfillmentBatch {
  id            String    @id @default(cuid())
  warehouseId   String
  status        String    @default("pending")
  totalOrders   Int       @default(0)
  totalItems    Int       @default(0)
  assignedAt    DateTime?
  pickedAt      DateTime?
  packedAt      DateTime?
  shippedAt     DateTime?

  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  items         FulfillmentBatchItem[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("fulfillment_batches")
}

model FulfillmentBatchItem {
  id              String  @id @default(cuid())
  batchId         String
  orderId         String
  productId       String
  quantity        Int
  pickedQuantity   Int     @default(0)
  status          String  @default("pending")

  batch           FulfillmentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("fulfillment_batch_items")
}

model ShippingProvider {
  id          String  @id @default(cuid())
  nameEn      String
  nameAr      String
  code        String  @unique
  apiEndpoint String  @default("")
  apiKey      String  @default("")
  isActive    Boolean @default(true)

  shipments   Shipment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("shipping_providers")
}

model Shipment {
  id              String    @id @default(cuid())
  orderId         String    @unique
  providerId      String?
  trackingNumber  String    @default("")
  status          String    @default("created")
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  weightKg        Float     @default(0)
  notes           String    @default("")

  order           Order          @relation(fields: [orderId], references: [id])
  provider        ShippingProvider? @relation(fields: [providerId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
  @@map("shipments")
}

// ============================================
// PAYMENT TRANSACTIONS
// ============================================

model PaymentTransaction {
  id              String    @id @default(cuid())
  orderId         String
  customerId      String
  provider        String    // cod, paymob, fawry, valu, instapay
  providerTxId    String    @default("")
  amount          Int       // piastres
  status          String    @default("pending")
  method          String    @default("cod")
  metadata        String    @default("{}")
  refundAmount    Int       @default(0)
  failureReason   String?
  processedAt     DateTime?
  refundedAt      DateTime?

  order           Order     @relation(fields: [orderId], references: [id])
  customer        Customer  @relation(fields: [customerId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@map("payment_transactions")
}

// ============================================
// LOYALTY PROGRAM
// ============================================

model LoyaltyProgram {
  id              String    @id @default(cuid())
  nameEn          String
  nameAr          String    @default("")
  type            String    // points, cashback, tiered
  pointsPerPiastre Float   @default(0.01)
  pointsValue     Int       @default(100)
  minRedemption   Int       @default(0)
  maxAccumulation Int?
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  endsAt          DateTime?

  transactions    LoyaltyTransaction[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id              String    @id @default(cuid())
  customerId      String
  programId       String
  orderId         String?
  points          Int
  type            String    // earn, redeem, bonus, expire, adjust
  descriptionEn   String    @default("")
  descriptionAr   String    @default("")
  expiresAt       DateTime?

  customer        Customer      @relation(fields: [customerId], references: [id])
  program         LoyaltyProgram @relation(fields: [programId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])

  createdAt       DateTime  @default(now())

  @@index([customerId])
  @@index([programId])
  @@map("loyalty_transactions")
}

// ============================================
// NOTIFICATION SUBSCRIPTIONS & LOGS
// ============================================

model NotificationSubscription {
  id            String   @id @default(cuid())
  customerId    String
  channel       String   // push, sms, email, whatsapp
  token         String   @default("")
  preferences   String   @default("{}")
  isActive      Boolean  @default(true)

  customer      Customer @relation(fields: [customerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerId, channel])
  @@map("notification_subscriptions")
}

model NotificationLog {
  id            String   @id @default(cuid())
  customerId    String
  channel       String
  titleEn       String
  titleAr       String
  bodyEn        String
  bodyAr        String
  type          String   @default("info")
  status        String   @default("pending")
  sentAt        DateTime?
  failureReason String?

  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([customerId])
  @@index([status])
  @@map("notification_logs")
}

// ============================================
// APP SETTINGS
// ============================================

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")

  @@map("app_settings")
}
